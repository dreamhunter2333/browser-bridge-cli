{
  "manifest_version": 3,
  "name": "Browser Bridge",
  "version": "0.1.0",
  "description": "CDP-like browser control via CLI",
  "permissions": [
    "activeTab",
    "scripting",
    "tabs",
    "debugger",
    "cookies",
    "webRequest",
    "storage",
    "alarms"
  ],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Browser Bridge",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
