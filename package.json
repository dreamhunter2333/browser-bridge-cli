{
  "name": "browser-bridge-cli",
  "version": "0.1.3",
  "description": "Control Chrome/Edge browser via CLI through a browser extension",
  "type": "module",
  "bin": {
    "browser-bridge-cli": "dist/cli.js"
  },
  "files": [
    "dist",
    "extension"
  ],
  "scripts": {
    "build": "bun build src/cli.ts --target node --outfile dist/cli.js && bun build src/server.ts --target node --outfile dist/server.js",
    "dev": "bun src/cli.ts",
    "dev:server": "bun src/server.ts",
    "prepublishOnly": "bun run build",
    "test": "npx playwright test"
  },
  "dependencies": {},
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@types/ws": "^8.5.0",
    "commander": "^12.1.0",
    "ws": "^8.17.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/dreamhunter2333/browser-bridge-cli.git"
  },
  "keywords": [
    "browser",
    "chrome",
    "cli",
    "devtools",
    "cdp",
    "extension"
  ],
  "license": "MIT"
}
